{
  "agents": {
    "defaults": {
      "workspace": "{{WORKSPACE_DIR}}",
      "models": {
        "bench/{{CLAW_MODEL}}": {
          "alias": "bench"
        }
      },
      "model": "bench/{{CLAW_MODEL}}",
      "heartbeat": {
        "every": "0m"
      }
    }
  },
  "models": {
    "mode": "replace",
    "providers": {
      "bench": {
        "api": "openai-completions",
        "apiKey": "{{CLAW_API_KEY}}",
        "baseUrl": "{{CLAW_BASE_URL}}",
        "models": [
          {
            "id": "{{CLAW_MODEL}}",
            "name": "{{CLAW_MODEL}}",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 128000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "skills": {
    "allowBundled": []
  },
  "plugins": {
    "enabled": false,
    "slots": {
      "memory": "none"
    }
  },
  "cron": {
    "enabled": false
  }
}
